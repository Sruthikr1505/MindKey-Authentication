# Environment Variables for EEG Authentication System
# Copy this file to .env and fill in your values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Database Configuration
DATABASE_URL=sqlite:///data/users.db
# For PostgreSQL: postgresql://user:password@localhost:5432/eeg_auth_db

# Model Configuration
MODELS_DIR=models
DATA_DIR=data
OUTPUTS_DIR=outputs

# Device Configuration
DEVICE=cpu  # or cuda

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Thresholds
AUTH_THRESHOLD=0.5
SPOOF_PERCENTILE=99.0

# Optional: Weights & Biases
# WANDB_API_KEY=your-wandb-api-key
# WANDB_PROJECT=eeg-authentication
# WANDB_ENTITY=your-username

# Optional: Kaggle (for dataset download)
# KAGGLE_USERNAME=your-kaggle-username
# KAGGLE_KEY=your-kaggle-key

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
